<?xml version="1.0" encoding="utf-8"?>
<Package xmlns="http://schemas.microsoft.com/appx/2010/manifest" 
         xmlns:m2="http://schemas.microsoft.com/appx/2013/manifest">
  
  <Identity Name="CodornizCorp.CodornizStore" Publisher="CN=CodornizCorp" Version="1.0.0.0" ProcessorArchitecture="neutral" />
  
  <Properties>
    <DisplayName>CodornizStore</DisplayName>
    <PublisherDisplayName>CodornizCorp</PublisherDisplayName>
    <Logo>images\StoreLogo.png</Logo>
    <Description>CodornizStore - A beautifully made store</Description>
  </Properties>
  
  <Prerequisites>
    <OSMinVersion>6.3.0</OSMinVersion>
    <OSMaxVersionTested>6.3.0</OSMaxVersionTested>
  </Prerequisites>
  
  <Resources>
    <Resource Language="es-ES" />
  </Resources>
  
  <Applications>
    <Application Id="App" StartPage="rwstore.html">
      <!-- Fíjate cómo usamos m2: para VisualElements y los elementos dentro -->
      <m2:VisualElements DisplayName="CodornizStore" 
                         Description="CodornizStore - A beautifully made store" 
                         ForegroundText="light" 
                         BackgroundColor="#008A00" 
                         Square150x150Logo="images\Square150x150Logo.png" 
                         Square30x30Logo="images\Square30x30Logo.png">
        <m2:DefaultTile Wide310x150Logo="images\Wide315x150Logo.png" 
                        ShortName="CodornizStore" />
        <m2:SplashScreen Image="images\splashscreen.scale-140.png" />
      </m2:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <Capability Name="internetClient" />
    <Capability Name="internetClientServer" />
    <Capability Name="privateNetworkClientServer" />
  </Capabilities>
</Package>