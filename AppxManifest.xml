<?xml version="1.0" encoding="utf-8"?>
<Package xmlns="http://microsoft.com" xmlns:m2="http://microsoft.com" xmlns:build="http://microsoft.com" IgnorableNamespaces="build">
  
  

  <Properties>
    <DisplayName>CodornizStore</DisplayName>
    <PublisherDisplayName>Rework</PublisherDisplayName>
    <Logo>images\codorniz.png</Logo>
  </Properties>

  <Prerequisites>
    <OSMinVersion>6.3.0</OSMinVersion>
    <OSMaxVersionTested>10.0.0.0</OSMaxVersionTested>
  </Prerequisites>

  <Dependencies>
    <PackageDependency Name="Microsoft.WinJS.2.0" MinVersion="1.0.9600.17018" />
  </Dependencies>

  <Resources>
    <Resource Language="EN-US" />
  </Resources>

  <Applications>
    <Application Id="CodornizStore" StartPage="rwstore.html">
      <m2:VisualElements DisplayName="CodornizStore" 
                         Description="Una tienda metro de la codorniz" 
                         ForegroundText="light" 
                         BackgroundColor="#1F1F1F"
                         Logo="images\codorniz.png"
                         SmallLogo="images\codorniz.png">
        <m2:DefaultTile Wide310x150Logo="images\codorniz.png" Square310x310Logo="images\codorniz.png" ShortName="CodornizStore">
          <m2:ShowNameOnTiles>
            <m2:ShowOn Tile="square150x150Logo" />
            <m2:ShowOn Tile="wide310x150Logo" />
          </m2:ShowNameOnTiles>
        </m2:DefaultTile>
        <m2:SplashScreen Image="images\codorniz.png" />
      </m2:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <Capability Name="internetClient" />
  </Capabilities>
</Package>
