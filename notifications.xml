<tile>
  <visual version="2">
    <!-- BALDOSA CUADRADA NATIVA -->
    <binding 
      template="TileSquare150x150Image"
      fallback="TileSquareImage">
      <image 
        id="1" 
        src="ms-appx:///images/codorniz.png" />
    </binding>
    <!-- BALDOSA ANCHA CON TU EJÉRCITO DE APPS -->
    <binding 
      template="TileWide310x150PeekImageCollection01">
      <!-- Los 4 iconos frontales de deidad -->
      <image 
        id="1" 
        src="ms-appx:///images/iconos_extraidos/angrybirds.png" />
      <image 
        id="2" 
        src="ms-appx:///images/iconos_extraidos/fruitninja.png" />
      <image 
        id="3" 
        src="ms-appx:///images/iconos_extraidos/freshpaint.png" />
      <image 
        id="4" 
        src="ms-appx:///images/iconos_extraidos/wpapp.png" />
      <!-- Descripciones directas sin relleno pendejo -->
      <text id="1">
        Angry Birds Space • Fruit Ninja
      </text>
      <text id="2">
        Fresh Paint • wpapp (Windows Phone)
      </text>
      <text id="3">
        Netflix • newsXpresso • WPCentral
      </text>
    </binding>
  </visual>
</tile>

